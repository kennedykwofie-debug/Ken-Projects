# DARKWATCH Intelligence Service — Environment Variables
# Copy to .env for local development. NEVER commit .env to git.
# In production, set these directly in Railway dashboard.

# ── Service ──────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
# Comma-separated API keys (min 32 chars each).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=your-32-char-minimum-key-here

# Comma-separated allowed CORS origins (empty = block all cross-origin)
ALLOWED_ORIGINS=https://ken-projects-production.up.railway.app

# Comma-separated allowed hosts (production only)
ALLOWED_HOSTS=ken-projects-production.up.railway.app

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway Redis add-on provides this automatically
REDIS_URL=redis://localhost:6379

# ── Geopolitical APIs ────────────────────────────────────────────────────────
# ACLED: free researcher account — https://developer.acleddata.com/
ACLED_KEY=your-acled-key
ACLED_EMAIL=your-acled-email@example.com

# ── Cyber APIs ────────────────────────────────────────────────────────────────
# AbuseIPDB: free 1000/day — https://www.abuseipdb.com/account/plans
ABUSEIPDB_KEY=your-abuseipdb-key

# Shodan: already in Railway env
SHODAN_KEY=your-shodan-key

# HIBP: already in Railway env
HIBP_KEY=your-hibp-key

# ── Economic APIs ─────────────────────────────────────────────────────────────
# FRED: free — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=your-fred-key

# Finnhub: free — https://finnhub.io/register
FINNHUB_KEY=your-finnhub-key

# ── AI / LLM (optional) ───────────────────────────────────────────────────────
# Groq: free tier sufficient — https://console.groq.com/
GROQ_KEY=your-groq-key
